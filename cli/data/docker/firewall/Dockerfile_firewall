FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
  iptables \
  ipset \
  iproute2 \
  curl \
  jq \
  dnsutils \
  aggregate \
  ca-certificates \
  procps \
  ulogd2 \
  && rm -rf /var/lib/apt/lists/*

COPY --chmod=755 firewall-init.sh firewall-apply.sh firewall-log.sh entrypoint-firewall.sh /usr/local/bin/
COPY ulogd.conf /etc/ulogd.conf

RUN mkdir -p /etc/firewall /var/log/sandbox/firewall

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD iptables -L -n > /dev/null 2>&1 || exit 1

CMD ["/usr/local/bin/entrypoint-firewall.sh"]
