# Sandbox Environment Configuration
# Copy to .env and customize as needed. On first run, `sandbox start`
# will copy this file automatically if .env is missing.

# Project name (used for Docker Compose project naming)
COMPOSE_PROJECT_NAME=project

# Timezone (auto-detected from host if left empty)
TZ=

# Audit logging
SANDBOX_LOG_DIR=./logs
SANDBOX_LOG_RETENTION_DAYS=30

# Corporate proxy (leave empty if not behind a proxy)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Custom CA certificate path (for corporate TLS inspection)
CUSTOM_CA_CERT_PATH=

# Environment profile (loads .env.{profile} if it exists)
# Example: SANDBOX_ENV=corp loads .env.corp
SANDBOX_ENV=

# Log format: text or json (json for corporate log agent compatibility)
SANDBOX_LOG_FORMAT=text

# Secrets provider: local (encrypted file) or env (environment variables)
SANDBOX_SECRETS_PROVIDER=local

# Log sinks: file, stdout, or file,stdout
SANDBOX_LOG_SINKS=file

# OpenTelemetry field compatibility (adds trace_id/span_id mapping)
SANDBOX_LOG_OTEL_COMPAT=false

# Max payload size in log entries (0 = no limit)
SANDBOX_LOG_MAX_PAYLOAD_BYTES=0

# Resource limits (empty = no limit)
SANDBOX_CPU_LIMIT=
SANDBOX_MEM_LIMIT=

# Hardened mode: read-only filesystem, drop all capabilities (default: false)
SANDBOX_HARDENED_MODE=false

# Offline mode: skip network-dependent operations during startup (default: false)
SANDBOX_OFFLINE_MODE=false
