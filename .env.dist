# Sandbox Environment Configuration
# Copy to .env and customize as needed. On first run, `sandbox start`
# will copy this file automatically if .env is missing.

# Project name (used for Docker Compose project naming)
COMPOSE_PROJECT_NAME=project

# Timezone (auto-detected from host if left empty)
TZ=

# Audit logging
SANDBOX_LOG_DIR=./logs
SANDBOX_LOG_RETENTION_DAYS=30

# Corporate proxy (leave empty if not behind a proxy)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Custom CA certificate path (for corporate TLS inspection)
CUSTOM_CA_CERT_PATH=
